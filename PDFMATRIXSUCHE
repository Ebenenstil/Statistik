import json

def load_matrix_from_json(json_file_path):
    """Lädt die Matrix aus einer JSON-Datei."""
    with open(json_file_path, 'r', encoding='utf-8') as json_file:
        matrix = json.load(json_file)
    return matrix

def extract_schueler_analyse(matrix):
    """Extrahiert Schülerdaten aus der Matrix."""
    schueler_analyse = []
    target_rows = []  # Liste zur Speicherung der target_rows und der nächsten Zeile

    for row_index, row in enumerate(matrix):
        # Suche nach Zeilen, die mit "Adr" beginnen
        if row[0] == "Adr":
            if row_index + 2 < len(matrix):  # Stelle sicher, dass die übernächste Zeile existiert
                target_row = matrix[row_index + 2]
                if row_index + 3 < len(matrix):  # Stelle sicher, dass die nächste Zeile existiert
                    next_row = matrix[row_index + 3]  # Die Zeile darunter
                
                # Suche nach 'z' in der target_row
                z_index = next((i for i, v in enumerate(target_row) if v == 'z'), None)
                z_value = target_row[z_index + 1] if z_index is not None and z_index + 1 < len(target_row) else None

                # Suche nach 'w' in der next_row
                w_index = next((i for i, v in enumerate(next_row) if v == 'w'), None)
                w_value = next_row[w_index + 1] if w_index is not None and w_index + 1 < len(next_row) else None

                # Füge die extrahierten Werte zur Liste hinzu
                schueler_analyse.append([target_row[1], target_row[2], z_value, w_value])
                target_rows.append((z_value, w_value))  # Füge die Werte für die Ausgabe hinzu

    return schueler_analyse, target_rows  # Gebe nun auch die target_rows zurück

def save_schueler_analyse_to_json(schueler_analyse, target_rows, json_file_path):
    """Speichert die SchuelerAnzahl-Daten in einer JSON-Datei."""
    output_data = {
        "SchuelerAnzahl": schueler_analyse,
        "TargetRows": [{"ZValue": row[0], "WValue": row[1]} for row in target_rows]  # Füge die extrahierten Werte hinzu
    }
    
    with open(json_file_path, 'w', encoding='utf-8') as json_file:
        json.dump(output_data, json_file, indent=4, ensure_ascii=False)
    print(f"SchuelerAnzahl in JSON-Datei gespeichert: {json_file_path}")

def save_schueler_analyse_to_txt(schueler_analyse, target_rows, txt_file_path):
    """Speichert die SchuelerAnzahl-Daten in einer Textdatei."""
    with open(txt_file_path, 'w', encoding='utf-8') as txt_file:
        txt_file.write("Target Rows:\n")
        for row in target_rows:
            txt_file.write('Z Value: ' + (str(row[0]) if row[0] is not None else 'None') + '\n')
            txt_file.write('W Value: ' + (str(row[1]) if row[1] is not None else 'None') + '\n')

        txt_file.write("\nSchuelerAnzahl:\n")
        for row in schueler_analyse:
            txt_file.write(' '.join(map(str, row)) + '\n')
    print(f"SchuelerAnzahl in TXT-Datei gespeichert: {txt_file_path}")

# Testaufruf
json_file_path = 'matrix_output.json'
matrix = load_matrix_from_json(json_file_path)

# Extrahiere die SchuelerAnzahl Daten
schueler_analyse, target_rows = extract_schueler_analyse(matrix)

# Speichere die extrahierten Daten als JSON und TXT
schueler_json_file = 'SchuelerAnzahl.json'
schueler_txt_file = 'SchuelerAnzahl.txt'

save_schueler_analyse_to_json(schueler_analyse, target_rows, schueler_json_file)
save_schueler_analyse_to_txt(schueler_analyse, target_rows, schueler_txt_file)
